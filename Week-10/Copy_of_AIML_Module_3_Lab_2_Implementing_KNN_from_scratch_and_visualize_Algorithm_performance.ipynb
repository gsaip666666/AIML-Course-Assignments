    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.datasets import load_iris\n",
        "from sklearn.decomposition import PCA\n",
        "from scipy.spatial import Voronoi, voronoi_plot_2d\n",
        "\n",
        "# 1. Load and Prepare Data\n",
        "data = load_iris()\n",
        "df = pd.DataFrame(data=data.data, columns=data.feature_names)\n",
        "X = df.values\n",
        "y = data.target\n",
        "\n",
        "# 2. Apply PCA to reduce to 2 dimensions [cite: 114]\n",
        "pca = PCA(n_components=2)\n",
        "X_pca = pca.fit_transform(X)\n",
        "\n",
        "# 3. Plot Voronoi Diagram for PCA-reduced data\n",
        "vor = Voronoi(X_pca)\n",
        "fig, ax = plt.subplots(figsize=(8, 6))\n",
        "voronoi_plot_2d(vor, ax=ax, show_vertices=False, line_colors='orange', line_width=2, line_alpha=0.6, point_size=10)\n",
        "plt.title(\"Voronoi Diagram of Iris Dataset (PCA-reduced)\")\n",
        "plt.show()\n",
        "\n",
        "# 4. Plot Decision Boundaries for PCA-reduced data\n",
        "# Note: Ensure decision_boundary_plot is defined in your environment as per the lab [cite: 228]\n",
        "decision_boundary_plot(X_pca, y, k=7)\n",
        "plt.show()"
      ],
